---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getPublishedPosts } from '../utils/posts';
import { SITE, withBase } from '../utils/site';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 6);
---

<BaseLayout>
  <section class="hero page-shell">
    <p class="eyebrow">Mandler J 的个人博客</p>
    <h1>让思考留下痕迹。</h1>
    <p class="hero-lead">
      {SITE.description} 在这里，我用章节、文字与表格，把模糊的感受整理成可以再次阅读的东西。
    </p>
  </section>

  <section class="section page-shell" aria-labelledby="latest-heading">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Latest notes</p>
        <h2 id="latest-heading">最近文章</h2>
      </div>
      <a class="text-link" href={withBase('/posts/')}>查看全部 <span aria-hidden="true">→</span></a>
    </div>
    {latestPosts.length > 0 ? <PostList posts={latestPosts} /> : <p class="empty-state">第一篇文章正在酝酿。</p>}
  </section>

  <section class="principle page-shell">
    <p class="eyebrow">About this place</p>
    <p>不是信息的仓库，而是一间持续整理认知的工作室。</p>
  </section>
</BaseLayout>
