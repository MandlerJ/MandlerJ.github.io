---
import { SITE, withBase } from '../utils/site';

const currentPath = Astro.url.pathname;
const links = [
  { href: withBase('/posts/'), label: '文章' },
  { href: withBase('/tags/'), label: '标签' },
  { href: withBase('/about/'), label: '关于' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="site-name" href={withBase('/')} aria-label={`${SITE.title} 首页`}>
      <span class="site-mark" aria-hidden="true"></span>
      {SITE.title}
    </a>
    <nav aria-label="主导航">
      <ul>
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li><a href={withBase('/rss.xml')}>RSS</a></li>
      </ul>
    </nav>
  </div>
</header>
